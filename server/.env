# MongoDB connection string
# For MongoDB Atlas, use the connection string from the Atlas UI, it will look like:
# mongodb+srv://<username>:<password>@<cluster-url>/pawsocial?retryWrites=true&w=majority
#
# For local MongoDB, you can use:
# mongodb://127.0.0.1:27017/pawsocial

MONGO_URL=mongodb+srv://<username>:<password>@<cluster-url>/pawsocial?retryWrites=true&w=majority

# Server port
PORT=4000
